<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- USUARIO -->
        <TextView
            android:id="@+id/tvUsuario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Usuario:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="#F5F5F5"
            android:gravity="start|center_vertical"
            android:padding="12dp"
            android:textColor="#333333"/>

        <!-- BOTON LOGOUT -->
        <Button
            android:id="@+id/btnLogout"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:text="Cerrar sesión"
            android:textSize="14sp"/>

    </LinearLayout>



    <EditText
        android:id="@+id/etCodigo"
        android:hint="Escanear código"
        android:textSize="22sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/etCantidad"
        android:hint="Cantidad"
        android:inputType="number"
        android:textSize="22sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="24dp">

        <!-- ZEBRA -->
        <LinearLayout
            android:id="@+id/layoutZebra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="5dp">

            <ImageView
                android:id="@+id/imgZebra"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_zebra"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zebra"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- DATAMAX -->
        <LinearLayout
            android:id="@+id/layoutDatamax"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="24dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="5dp">

            <ImageView
                android:id="@+id/imgDatamax"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_datamax"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Datamax"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- SEWOO -->
        <LinearLayout
            android:id="@+id/layoutSewoo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="24dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="5dp">

            <ImageView
                android:id="@+id/imgSewoo"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_sewoo"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sewoo"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvResultado"
        android:textSize="18sp"
        android:textColor="#006400"
        android:layout_marginTop="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>


</LinearLayout>